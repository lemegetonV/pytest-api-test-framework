{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DummyJSON post collection",
  "type": "object",
  "required": ["posts", "total", "skip", "limit"],
  "properties": {
    "posts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "body", "tags", "reactions", "views", "userId"],
        "properties": {
          "id": {"type": "integer"},
          "title": {"type": "string", "minLength": 1},
          "body": {"type": "string", "minLength": 1},
          "tags": {"type": "array", "items": {"type": "string"}},
          "reactions": {
            "type": "object",
            "required": ["likes", "dislikes"],
            "properties": {
              "likes": {"type": "integer"},
              "dislikes": {"type": "integer"}
            },
            "additionalProperties": true
          },
          "views": {"type": "integer"},
          "userId": {"type": "integer"}
        },
        "additionalProperties": true
      }
    },
    "total": {"type": "integer"},
    "skip": {"type": "integer"},
    "limit": {"type": "integer"}
  },
  "additionalProperties": true
}
