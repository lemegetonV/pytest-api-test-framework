{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DummyJSON product",
  "type": "object",
  "required": ["id", "title", "description", "category", "price", "rating", "stock", "tags", "dimensions", "reviews"],
  "properties": {
    "id": {"type": "integer"},
    "title": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "category": {"type": "string", "minLength": 1},
    "price": {"type": "number"},
    "discountPercentage": {"type": "number"},
    "rating": {"type": "number"},
    "stock": {"type": "integer"},
    "tags": {"type": "array", "items": {"type": "string"}},
    "brand": {"type": "string"},
    "sku": {"type": "string"},
    "dimensions": {
      "type": "object",
      "required": ["width", "height", "depth"],
      "properties": {
        "width": {"type": "number"},
        "height": {"type": "number"},
        "depth": {"type": "number"}
      },
      "additionalProperties": true
    },
    "reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rating", "comment", "reviewerName", "reviewerEmail"],
        "properties": {
          "rating": {"type": "integer"},
          "comment": {"type": "string"},
          "reviewerName": {"type": "string"},
          "reviewerEmail": {"type": "string", "format": "email"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
