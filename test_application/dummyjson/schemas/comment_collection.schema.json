{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DummyJSON comment collection",
  "type": "object",
  "required": ["comments", "total", "skip", "limit"],
  "properties": {
    "comments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "body", "postId", "likes", "user"],
        "properties": {
          "id": {"type": "integer"},
          "body": {"type": "string", "minLength": 1},
          "postId": {"type": "integer"},
          "likes": {"type": "integer"},
          "user": {
            "type": "object",
            "required": ["id", "username", "fullName"],
            "properties": {
              "id": {"type": "integer"},
              "username": {"type": "string", "minLength": 1},
              "fullName": {"type": "string", "minLength": 1}
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "total": {"type": "integer"},
    "skip": {"type": "integer"},
    "limit": {"type": "integer"}
  },
  "additionalProperties": true
}
